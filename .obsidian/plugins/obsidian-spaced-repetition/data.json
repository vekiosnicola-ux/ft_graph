{
  "flashcardTags": ["#flashcard", "#review"],
  "cardTag": "#flashcard",
  "reviewDeckTagPrefix": "#deck/",
  "convertFoldersToDecks": true,
  "singleLineCommentOnSameLine": false,
  "singleLineCardSeparator": "::",
  "singleLineReversedCardSeparator": ":::",
  "multilineCardSeparator": "???",
  "multilineReversedCardSeparator": "????",
  "clozePatterns": ["==", "**"],
  "codeblockCardSeparator": "```",
  "contextAwareMode": true,
  "showContextInCards": true,
  "showContextInReview": true,
  "supportMath": false,
  "supportImage": true,
  "supportAudio": false,
  "supportVideo": false,
  "burySiblingCards": true,
  "showFileNameInFileLink": true,
  "randomizeCardOrder": true,
  "convertHighlightsToClozes": true,
  "convertBoldTextToClozes": false,
  "disableClozeCards": false,
  "disableSinglelineCards": false,
  "disableMultilineCards": false,
  "disableSinglelineReversedCards": false,
  "disableMultilineReversedCards": false,
  "enableNoteReviewPaneOnStartup": true,
  "maximumIntervalInDays": 36500,
  "baseEase": 250,
  "lapsesIntervalChange": 0.5,
  "easyBonus": 1.3,
  "loadBalancer": {
    "enabled": true,
    "maxCardsPerDay": 50
  }
}
